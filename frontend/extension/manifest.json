{
  "manifest_version": 3,
  "name": "Civic Info HUD",
  "version": "0.1.0",
  "description": "Double-click any politician name to see your alignment score and their top implemented policies.",
  "permissions": ["activeTab", "storage", "scripting"],
  "background": {
    "service_worker": "scripts/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["scripts/content.js"]
    }
  ],
  "action": {
    "default_popup": "ui/card.html"
  }
}
